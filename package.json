{
	"name": "directus-extension-transform-image-on-upload",
	"description": "Directus hook extension for image optimization using directus's AssetsService",
	"icon": "extension",
	"version": "1.0.1",
	"license": "MIT",
	"author": {
		"email": "jeanjacketz@protonmail.com",
		"name": "jeanjacketz"
	},
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-hook"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "hook",
		"path": "dist/index.js",
		"source": "src/index.ts",
		"host": "^11.17.4"
	},
	"scripts": {
		"build": "directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"validate": "directus-extension validate"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "17.1.3",
		"@directus/types": "^15.0.2",
		"@types/node": "^25.6.0",
		"typescript": "^6.0.3"
	}
}